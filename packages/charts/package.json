{
  "name": "@xpanse/native-charts",
  "version": "1.0.0",
  "private": false,
  "description": "React Native chart + table pipeline built on @wuba/react-native-echarts and @tanstack/react-table",
  "source": "src/index.ts",
  "react-native": "src/index.ts",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./server": {
      "import": {
        "types": "./lib/typescript/server/index.d.ts",
        "default": "./lib/module/server/index.js"
      },
      "require": {
        "types": "./lib/typescript/server/index.d.ts",
        "default": "./lib/commonjs/server/index.js"
      }
    }
  },
  "files": [
    "lib/",
    "src/"
  ],
  "publishConfig": {
    "registry": "https://nexus.internal/repository/npm-hosted/",
    "access": "restricted"
  },
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "prepare": "bob build"
  },
  "peerDependencies": {
    "@tanstack/react-table": ">=8",
    "@wuba/react-native-echarts": ">=3",
    "echarts": ">=6",
    "i18next": ">=23",
    "react": ">=19",
    "react-i18next": ">=14",
    "react-native": ">=0.80"
  },
  "peerDependenciesMeta": {
    "i18next": { "optional": true },
    "react-i18next": { "optional": true }
  },
  "devDependencies": {
    "@react-native/typescript-config": "0.83.2",
    "react-native-builder-bob": "^0.40.0",
    "typescript": "^5.8.3"
  }
}
