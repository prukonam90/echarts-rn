{
  "name": "echarts-rn",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm --filter @xpanse/native-charts build && pnpm changeset publish",
    "prepare": "lefthook install",
    "pod-install": "bundle exec pod install --project-directory=ios",
    "test:e2e": "maestro test .maestro/homeValue/smoke.yaml .maestro/homeValue/range-selection.yaml .maestro/homeEquity/smoke.yaml",
    "test:e2e:homeValue": "maestro test .maestro/homeValue/smoke.yaml .maestro/homeValue/range-selection.yaml",
    "test:e2e:homeEquity": "maestro test .maestro/homeEquity/smoke.yaml"
  },
  "dependencies": {
    "@xpanse/native-charts": "workspace:*",
    "@react-native/new-app-screen": "0.83.2",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "@wuba/react-native-echarts": "^3.0.1",
    "echarts": "^6.0.0",
    "i18next": "^26.1.0",
    "react": "19.2.0",
    "react-i18next": "^17.0.7",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "zrender": "6.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@evilmartians/lefthook": "^1.11.13",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.2",
    "@react-native/eslint-config": "0.83.2",
    "@react-native/metro-config": "0.83.2",
    "@react-native/typescript-config": "0.83.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "resolutions": {
    "tslib": "^2.8.1"
  },
  "overrides": {
    "tslib": "^2.8.1"
  }
}
