# Private Nexus npm registry auth token
NEXUS_AUTH_TOKEN=

# CDN base URL for chart templates and mock data
# Default: https://cdn.xpanse.io/native-charts
XPANSE_CHARTS_CDN_URL=

# S3 / AWS — used by CI/CD to publish chart templates (not needed locally)
AWS_REGION=us-east-1
S3_BUCKET=xpanse-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: CloudFront distribution ID for cache invalidation after template publish
CLOUDFRONT_DISTRIBUTION_ID=
